# Google AI Studio (Gemini) API key for bill explanations (https://aistudio.google.com/apikey)
# If unset, the build still succeeds and AI explanations are null (backfilled later).
GEMINI_API_KEY=
# gemma-4-31b-it works on the free tier and supports grounding; gemini-2.5-flash
# is a fine alternative. (Gemini 3.x and gemma-4-26b-a4b-it are unreliable on free tier.)
GEMINI_MODEL=gemma-4-31b-it

# Diet session to build (defaults to latest available in the SMRI data)
SESSION=221
